# Env variable names are case sensitive — spell exactly as shown

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.uzw2cal.mongodb.net/mango-books?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=mango-books
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-long
