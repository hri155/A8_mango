# Copy these values into Vercel → Project → Settings → Environment Variables
# Live site: https://mango-books-virid.vercel.app

MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=mango-books
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-long
BETTER_AUTH_URL=https://mango-books-virid.vercel.app
NEXT_PUBLIC_APP_URL=https://mango-books-virid.vercel.app
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
