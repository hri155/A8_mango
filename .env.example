# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.uzw2cal.mongodb.net/mango-books?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=mango-books

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-key-min-32-chars-long

# --- Local development ---
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Production (Vercel) ---
# BETTER_AUTH_URL=https://mango-books-virid.vercel.app
# NEXT_PUBLIC_APP_URL=https://mango-books-virid.vercel.app

# Google OAuth (from Google Cloud Console)
# Add redirect URI for local: http://localhost:3000/api/auth/callback/google
# Add redirect URI for live: https://mango-books-virid.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
